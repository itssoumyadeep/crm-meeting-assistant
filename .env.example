# Local development configuration
# For deployment, these are set via Terraform / the deploy command.

# Vertex AI Configuration (default)
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# Alternatively, for Gemini API via Google AI Studio,
# comment out the three lines above and uncomment:
# GEMINI_API_KEY=your-api-key-here

# ─────────────────────────────────────────────
# CRM Meeting Assistant — optional overrides
# (all have safe defaults; only set if needed)
# ─────────────────────────────────────────────

# Filesystem path to the SQLite database (default: project_root/crm_assistant.db)
# CRM_DB_PATH=/custom/path/to/crm_assistant.db

# Gemini model name — do NOT change without explicit approval
# CRM_MODEL_NAME=gemini-flash-latest

# Number of automatic retries on transient LLM errors
# CRM_MODEL_RETRY_ATTEMPTS=3

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
# CRM_LOG_LEVEL=INFO

